{
  "name": "savant",
  "version": "8.0.0",
  "description": "Savant — AI Session Dashboard",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "EB_TELEMETRY=0 ELECTRON_BUILDER_OFFLINE=1 electron-builder --mac",
    "dev": "NODE_ENV=development electron .",
    "test": "node --test tests/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage tests/*.test.js",
    "test:frontend": "node tests_js/test_context_modules.js && node tests_js/test_terminal_integration.js",
    "test:ui": "playwright test tests_ui --reporter=line"
  },
  "author": "Project X",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.icapital.savant",
    "productName": "Savant",
    "releaseInfo": {
      "releaseNotes": "v8.0.0 HERO RELEASE: Client-Server Rewrite. Savant is now split into savant-app (Electron client) and savant-server (API + MCP backend). The client owns UI, terminal, D3 visuals, local cache and offline mutation queue; the server owns centralized data, knowledge graph, API orchestration, and MCP tools."
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icon.png",
      "target": [
        "dmg",
        "dir"
      ]
    },
    "files": [
      "main.js",
      "client_store.js",
      "preload.js",
      "icon.png",
      "loading.html",
      "offline.html",
      "terminal.html",
      "renderer/**/*",
      "hermes_skills/**/*"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "dmg": {
      "title": "Savant",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "@electron/rebuild": "^4.0.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  }
}
